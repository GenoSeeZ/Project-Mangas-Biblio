{% extends 'base.html.twig' %}

{% block title %}{{ manga.title }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-8">
        <h2 class="fw-bold mb-1">{{ manga.title }}</h2>
        <p class="text-muted mb-3">{{ manga.author }} · {{ manga.releaseYear }}</p>
        <p>{{ manga.description }}</p>

        <ul class="list-unstyled text-muted small">
            <li><strong>Genres :</strong> {{ manga.genres|join(', ') }}</li>
            <li><strong>Statut :</strong> {{ manga.status }}</li>
            <li><strong>Ajouté le :</strong> {{ manga.createdAt|date('d/m/Y') }}</li>
        </ul>

        {% if app.user %}
            <a href="{{ path('app_library_add', {'id': manga.id}) }}" class="btn btn-success mt-2">
                + Ajouter à ma bibliothèque
            </a>
        {% endif %}

        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_manga_edit', {'id': manga.id}) }}" class="btn btn-outline-secondary mt-2">Éditer</a>
            {{ include('manga/_delete_form.html.twig') }}
        {% endif %}
    </div>
</div>

<div class="mt-4">
    <a href="{{ path('app_manga_index') }}" class="text-muted small">← Retour à la liste</a>
</div>
{% endblock %}