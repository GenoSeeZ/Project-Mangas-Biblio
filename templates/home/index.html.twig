{% extends 'base.html.twig' %}

{% block title %}Accueil - Bibliothèque de mangas{% endblock %}

{% block body %}
<div class="text-center py-5">
    <h2 class="fw-bold mb-3">Bienvenue sur MyMangaLibrary</h2>
    <p class="text-muted mb-4">Gérez votre collection de mangas personnel.</p>

    {% if app.user %}
        <a href="{{ path('app_manga_index') }}" class="btn btn-primary btn-lg">
            Voir les mangas
        </a>
    {% else %}
        <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg me-2">S'inscrire</a>
        <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-lg">Se connecter</a>
    {% endif %}
</div>
{% endblock %}