{% extends 'base.html.twig' %}

{% block title %}Ma bibliothèque{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Ma bibliothèque</h2>
    <a href="{{ path('app_manga_index') }}" class="btn btn-outline-primary btn-sm">+ Ajouter des mangas</a>
</div>

{% if userMangas is empty %}
    <div class="text-center text-muted py-5">
        <p>Votre bibliothèque est vide.</p>
        <a href="{{ path('app_manga_index') }}" class="btn btn-primary">Parcourir les mangas</a>
    </div>
{% else %}
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for userManga in userMangas %}
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">{{ userManga.manga.title }}</h5>
                    <p class="card-text text-muted small">{{ userManga.manga.author }}</p>

                    <span class="badge 
                        {% if userManga.readingStatus == 'completed' %}bg-success
                        {% elseif userManga.readingStatus == 'reading' %}bg-primary
                        {% else %}bg-secondary{% endif %}">
                        {% if userManga.readingStatus == 'completed' %}Lu
                        {% elseif userManga.readingStatus == 'reading' %}En lecture
                        {% else %}À lire{% endif %}
                    </span>
                </div>
                <div class="card-footer d-flex gap-2">
                    <form method="post" action="{{ path('app_library_status', {'id': userManga.id}) }}" class="d-flex gap-1 flex-grow-1">
                        <select name="status" class="form-select form-select-sm">
                            <option value="to_read" {% if userManga.readingStatus == 'to_read' %}selected{% endif %}>À lire</option>
                            <option value="reading" {% if userManga.readingStatus == 'reading' %}selected{% endif %}>En lecture</option>
                            <option value="completed" {% if userManga.readingStatus == 'completed' %}selected{% endif %}>Lu</option>
                        </select>
                        <button class="btn btn-sm btn-outline-primary">OK</button>
                    </form>
                    <form method="post" action="{{ path('app_library_remove', {'id': userManga.id}) }}">
                        <button class="btn btn-sm btn-outline-danger">✕</button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}